# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings for RAG)
OPENAI_API_KEY=sk-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe Dashboard under Products
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_QUARTERLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_QUARTERLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_QUARTERLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...

# Stripe Credit Pack Price IDs (one-time payments)
STRIPE_PRICE_CREDITS_5=price_...
STRIPE_PRICE_CREDITS_20=price_...
STRIPE_PRICE_CREDITS_60=price_...
